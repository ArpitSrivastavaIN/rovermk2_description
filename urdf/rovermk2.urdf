            <geometry>
                <box size="0.65 0.05 0.04" />
            </geometry>
        </collision>
    </link>

    <!-- Suspension Joints Closed Loop thus with gazebo tags -->

    <joint name="susleft_joint" type="fixed">
        <origin xyz="-0.175 -0.01 0.043" rpy="0 0 -1.5708" />
        <parent link="base_link" />
        <child link="suspension_left" />
        <axis xyz="0 1 0" />
        <limit lower="-0.174" upper="0.174" effort="100" velocity="1" />
    </joint>

    <joint name="susright_joint" type="fixed">
        <origin xyz="0.175 -0.01 0.043" rpy="0 1.7626E-05 -1.5708" />
        <parent link="base_link" />
        <child link="suspension_right" />
        <axis xyz="0 1 0" />
        <limit lower="-0.174" upper="0.174" effort="100" velocity="1" />
    </joint>


    <!-- Steer Joints and Links -->

