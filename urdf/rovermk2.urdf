<?xml version="1.0" encoding="utf-8"?>
<robot name="rovermk2">

    <!-- Base Link  -->

    <link name="base_link">
        <inertial>
            <origin xyz="1.5107E-12 -0.010391 0.059342" rpy="0 0 0" />
            <!-- <mass value="3.9684" />
            <inertia ixx="0.068308" ixy="2.8787E-12" ixz="-8.8418E-14" iyy="0.03715"
                iyz="0.00010785" izz="0.091228" /> -->
            <mass value="20.0" />
            <inertia ixx="0.34424" ixy="1.4503E-11" ixz="-4.4546E-13"
                iyy="0.18723"
                iyz="0.00054354" izz="0.45979" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://rovermk2_description/meshes/base_link.STL" />
            </geometry>
            <material name="">
                <color rgba="0.96471 0.96471 0.95294 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0" />
            <geometry>
                <box size="0.28 0.35 0.15" />
            </geometry>
        </collision>
    </link>

    <!-- Suspension Links -->

    <link name="suspension_left">
        <inertial>
            <origin xyz="-0.085081 0.00042119 -0.0073347" rpy="0 0 0" />
            <!-- <mass value="0.69456" />
            <inertia ixx="0.00041573" ixy="-1.6646E-10" ixz="-3.1978E-09" iyy="0.0014467"
                iyz="2.2187E-10" izz="0.0017365" /> -->
            <mass value="5.0" />
            <inertia ixx="0.0029927" ixy="-1.1983E-09" ixz="-2.3018E-08"
                iyy="0.0104136"
                iyz="1.5973E-09" izz="0.0125038" />
        </inertial>
        <visual>
            <origin xyz="0.08875 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://rovermk2_description/meshes/suspension_1.STL" />
            </geometry>
            <material name="">
                <color rgba="0.96471 0.96471 0.95294 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="-0.01 0 -0.007" rpy="0 0 0" />
            <geometry>
                <box size="0.65 0.05 0.04" />
            </geometry>
        </collision>
    </link>

    <link name="suspension_right">
        <inertial>
            <origin xyz="0.0048172 -0.047933 -0.0073349" rpy="0 0 0" />
