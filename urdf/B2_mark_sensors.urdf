<?xml version="1.0" encoding="utf-8"?>
<robot name="rovermk2">

    <!-- IMU Sensor with gaussian -->
    <link name="imu_link">
        <visual>
            <geometry>
                <box size="0.05 0.05 0.02" />
            </geometry>
        </visual>
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link" />
        <child link="imu_link" />
        <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>

    <gazebo reference="imu_link">
        <sensor name="imu_sensor" type="imu">
            <always_on>1</always_on>
            <update_rate>100</update_rate>
            <topic>/imu</topic>
            <gz_frame_id>imu_link</gz_frame_id>
            <noise>
                <type>gaussian</type>
                <mean>0.0</mean>
                <stddev>0.02</stddev>
            </noise>
        </sensor>
    </gazebo>

    <!-- GPS Sensor -->
    <link name="gps_link">
        <visual>
            <geometry>
                <box size="0.05 0.05 0.02" />
            </geometry>
        </visual>
    </link>

    <joint name="gps_joint" type="fixed">
        <parent link="base_link" />
        <child link="gps_link" />
        <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>

    <gazebo reference="gps_link">
        <sensor name="navsat_sensor" type="navsat">
            <always_on>1</always_on>
            <update_rate>100</update_rate>
            <topic>/gps</topic>
            <gz_frame_id>gps_link</gz_frame_id>
        </sensor>
    </gazebo>

    <!-- Depth Camera -->
    <link name="depth_camera_link">
        <visual>
            <geometry>
                <box size="0.09 0.025 0.025" />
            </geometry>
            <material name="">
                <color rgba="0.2 0.2 0.2 1" />
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.09 0.025 0.025" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1" />
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
        </inertial>
    </link>

    <joint name="depth_camera_joint" type="fixed">
        <parent link="base_link" />
        <child link="depth_camera_link" />
        <origin xyz="-0.1 0.15 0.225" rpy="0 0 0" />
    </joint>

    <link name="depth_camera_optical_frame" />

    <joint name="depth_camera_optical_joint" type="fixed">
        <parent link="depth_camera_link" />
        <child link="depth_camera_optical_frame" />
        <origin xyz="-0.1 0.15 0.225" rpy="0 0 0" />
    </joint>

    <!-- <gazebo reference="depth_camera_link">
        <sensor name="depth_camera" type="depth_camera">
            <always_on>true</always_on>
            <update_rate>30</update_rate>
            <topic>/depth_camera</topic>
            <gz_frame_id>depth_camera_optical_frame</gz_frame_id>
            <camera>
                <horizontal_fov>1.047</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R_FLOAT32</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>10.0</far>
                </clip>
            </camera>
        </sensor>
    </gazebo> -->
    <gazebo reference="depth_camera_link">
        <sensor name="depth_camera" type="rgbd">
            <always_on>true</always_on>
            <update_rate>10</update_rate>
            <topic>/depth_camera</topic>
            <gz_frame_id>depth_camera_optical_frame</gz_frame_id>
            <camera>
                <horizontal_fov>1.047</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>10.0</far>
                </clip>
            </camera>
        </sensor>
    </gazebo>

    <gazebo>
        <plugin
            filename="ignition-gazebo-odometry-publisher-system"
            name="ignition::gazebo::systems::OdometryPublisher">
            <ros>
                <namespace>/</namespace>
                <remapping>odom:=odom_raw</remapping>
                <parameter name="use_sim_time" type="bool">true</parameter>
            </ros>
            <body_name>base_link</body_name>
            <frame_name>odom</frame_name>
            <publish_odom_tf>true</publish_odom_tf>
            <update_rate>10</update_rate>
            <xyz_offset>0 0 0</xyz_offset>
            <rpy_offset>0 0 0</rpy_offset>
            <gaussian_noise>0.01</gaussian_noise>
        </plugin>
    </gazebo>


</robot>